# Add `~/bin` to the `$PATH`
export PATH="$HOME/bin:$PATH";

# Add MATLAB in the path
export PATH="/Applications/MATLAB_R2024a.app/bin:$PATH"

# For a2x, needed for git-latexdiff?
export XML_CATALOG_FILES="/usr/local/etc/xml/catalog"

# For tree in ~/bin/bin on greenplanet
export PATH=$PATH:~/bin/bin

# For texlive
export PATH="/usr/local/texlive/2026/bin/universal-darwin:$PATH"

# For Homebrew curl to override macOS curl
export PATH="$(brew --prefix)/opt/curl/bin:$PATH"
